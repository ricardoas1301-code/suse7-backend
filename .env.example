# Copiar para .env.local na sua máquina; não commitar valores reais.
# Local/DEV: use app Mercado Livre DEV e Supabase DEV. Produção: somente Vercel.

FRONTEND_URL=
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=

ML_LOCAL_DEV_FORBIDDEN_CLIENT_IDS=
ML_LOCAL_DEV_EXPECTED_CLIENT_ID=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

ML_WEBHOOK_JOB_SECRET=
JOB_SECRET=

S7_PROD_WEBHOOK_JOB_URL=

# Billing / Asaas (backend-only; nunca expor no frontend)
BILLING_PROVIDER_DEFAULT=asaas
ASAAS_ENV=sandbox
# Sandbox oficial: https://api-sandbox.asaas.com/v3
ASAAS_API_BASE_URL=
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# S7 Central Notifications — WhatsApp (Fase 3.5A–3.5C / canal oficial S5.6)
# DEV default: mock. Lab sandbox: dev_sandbox + whitelist.
# Live: exige S7_ALLOW_LIVE_DELIVERY=true em DEV/STAGING.
S7_APP_ENV=development
S7_ALLOW_LIVE_DELIVERY=false
S7_WHATSAPP_MODE=mock
# Provider ativo (WHATSAPP_PROVIDER tem precedência sobre S7_WHATSAPP_PROVIDER)
WHATSAPP_PROVIDER=mock
S7_WHATSAPP_PROVIDER=mock
S7_WHATSAPP_SANDBOX_WHITELIST=
S7_INTERNAL_NOTIFICATION_SECRET=
# Fase 3.5C.1 — Z-API live controlado (DEV/STAGING apenas)
# S7_WHATSAPP_MODE=live
# S7_WHATSAPP_PROVIDER=zapi
# S7_ALLOW_LIVE_DELIVERY=true
# S7_ZAPI_BASE_URL=https://api.z-api.io/instances/INSTANCE_ID/token/INSTANCE_TOKEN
# S7_ZAPI_TOKEN=
# S7_PROVIDER_SMOKE_ENABLED=true
# S7_PROVIDER_SMOKE_SELLER=
# S7_PROVIDER_SMOKE_PHONE=5511999999999
# Opcional legado: ZAPI_TOKEN
# Outros providers (futuro): EVOLUTION_API_KEY, META_WHATSAPP_TOKEN, TWILIO_AUTH_TOKEN

# S7 Central Notifications — E-mail (Fase 3.4 / canal oficial S5.5)
# Domínio oficial de envio: suse7.com.br (SPF/DKIM/DMARC no Resend)
S7_EMAIL_MODE=mock
S7_EMAIL_PROVIDER=mock
S7_EMAIL_FROM=Suse7 <notificacoes@suse7.com.br>
S7_EMAIL_SANDBOX_WHITELIST=
# Live DEV: S7_EMAIL_MODE=dev_sandbox S7_EMAIL_PROVIDER=resend RESEND_API_KEY=re_...
# RESEND_API_KEY= / SENDGRID_API_KEY=

# Fale Conosco — Motor Central (Fase S5.13) — exige Resend real (sem mock silencioso)
# S7_FALE_CONOSCO_SYSTEM_SELLER_ID=00000000-0000-0000-0000-000000000001
# S7_FALE_CONOSCO_INBOX_EMAIL=contato@suse7.com.br
# S7_EMAIL_PROVIDER=resend S7_EMAIL_MODE=live RESEND_API_KEY=re_...

# Jobs billing (cron GitHub Actions / X-Job-Secret)
# DEV: DEV_BILLING_PROCESS_PERIOD_EXPIRATIONS_JOB_URL -> .../api/jobs/billing-process-period-expirations
# DEV: DEV_BILLING_PROCESS_OVERDUES_JOB_URL -> .../api/jobs/billing-process-overdues
# PROD: S7_PROD_BILLING_PROCESS_PERIOD_EXPIRATIONS_JOB_URL / S7_PROD_BILLING_PROCESS_OVERDUES_JOB_URL
