# Copiar para .env.local na sua máquina; não commitar valores reais.
# Local/DEV: use app Mercado Livre DEV e Supabase DEV. Produção: somente Vercel.

FRONTEND_URL=
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=

ML_LOCAL_DEV_FORBIDDEN_CLIENT_IDS=
ML_LOCAL_DEV_EXPECTED_CLIENT_ID=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

ML_WEBHOOK_JOB_SECRET=
JOB_SECRET=

S7_PROD_WEBHOOK_JOB_URL=

# Billing / Asaas (backend-only; nunca expor no frontend)
BILLING_PROVIDER_DEFAULT=asaas
ASAAS_ENV=sandbox
# Sandbox oficial: https://api-sandbox.asaas.com/v3
ASAAS_API_BASE_URL=
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# Jobs billing (cron GitHub Actions / X-Job-Secret)
# DEV: DEV_BILLING_PROCESS_PERIOD_EXPIRATIONS_JOB_URL -> .../api/jobs/billing-process-period-expirations
# DEV: DEV_BILLING_PROCESS_OVERDUES_JOB_URL -> .../api/jobs/billing-process-overdues
# PROD: S7_PROD_BILLING_PROCESS_PERIOD_EXPIRATIONS_JOB_URL / S7_PROD_BILLING_PROCESS_OVERDUES_JOB_URL
