# Em DEV: use o MESMO projeto do frontend (VITE_SUPABASE_URL do .env.development).
# Senão o backend retorna 401 ao validar o token.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

FRONTEND_URL=http://localhost:5173

# Origens permitidas (CORS), separadas por vírgula. Inclua o host do frontend DEV na Vercel.
# Produção: https://suse7.com.br,https://www.suse7.com.br
# Backend DEV (Vercel): inclua a URL exata do preview/produção do frontend DEV.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Mercado Livre — use credenciais da app correta (DEV vs PROD nunca misturar).
# ML_REDIRECT_URI deve ser IDÊNTICA à cadastrada no painel do app ML (inclui https, path, sem barra extra).
ML_CLIENT_ID=your-ml-client-id
ML_CLIENT_SECRET=your-ml-client-secret

# Exemplo backend DEV na Vercel:
# ML_REDIRECT_URI=https://suse7-backend-dev.vercel.app/api/ml/callback
# FRONTEND_URL=https://seu-frontend-dev.vercel.app
ML_REDIRECT_URI=https://suse7-backend-dev.vercel.app/api/ml/callback

