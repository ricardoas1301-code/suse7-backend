{
  "name": "suse7-backend",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node ./src/dev-server.js",
    "dev:vercel": "vercel dev --listen 3001",
    "start": "node -e \"console.log('Use: npm run dev (local) or npm run dev:vercel')\"",
    "smoke:dev-center-customers-boundary": "node ./scripts/smoke_dev_center_customers_boundary.mjs",
    "test:dev-center-access": "node ./scripts/test_dev_center_access_unit.mjs",
    "test:dev-center-customers-input": "node ./scripts/test_dev_center_customers_input_unit.mjs",
    "smoke:dev-center-customers-hardening": "node ./scripts/smoke_dev_center_customers_hardening.mjs",
    "validate:dev-center-customers-global": "npm run test:dev-center-access && npm run test:dev-center-customers-input && npm run smoke:dev-center-customers-hardening && npm run smoke:dev-center-customers-boundary"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1",
    "@vercel/functions": "^3.0.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "node-fetch": "^3.3.2"
  }
}
