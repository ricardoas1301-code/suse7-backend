    "smoke:dev-center-customers-boundary": "node ./scripts/smoke_dev_center_customers_boundary.mjs",
    "test:dev-center-access": "node ./scripts/test_dev_center_access_unit.mjs",
    "test:dev-center-customers-input": "node ./scripts/test_dev_center_customers_input_unit.mjs",
    "smoke:dev-center-customers-hardening": "node ./scripts/smoke_dev_center_customers_hardening.mjs",
    "validate:dev-center-customers-global": "npm run test:dev-center-access && npm run test:dev-center-customers-input && npm run smoke:dev-center-customers-hardening && npm run smoke:dev-center-customers-boundary",
    "test:communication-contract": "node ./scripts/test_communication_contract_unit.mjs",
    "test:dispatcher-central": "node ./scripts/test_dispatcher_central_unit.mjs",
    "test:channel-registry": "node ./scripts/test_channel_registry_unit.mjs",
    "test:templates-central": "node ./scripts/test_templates_central_unit.mjs",
    "test:email-channel-official": "node ./scripts/test_email_channel_official_unit.mjs",
    "test:whatsapp-channel-official": "node ./scripts/test_whatsapp_channel_official_unit.mjs",
    "test:popup-channel-official": "node ./scripts/test_popup_channel_official_unit.mjs",
    "test:sininho-channel-official": "node ./scripts/test_sininho_channel_official_unit.mjs",
    "test:communication-preferences-official": "node ./scripts/test_communication_preferences_official_unit.mjs",
    "test:motor-observability-official": "node ./scripts/test_motor_observability_official_unit.mjs",
    "test:notification-catalog-official": "node ./scripts/test_notification_catalog_official_unit.mjs",
    "test:rayx-whatsapp-motor-official": "node ./scripts/test_rayx_whatsapp_motor_official_unit.mjs",
    "test:fale-conosco-motor-official": "node ./scripts/test_fale_conosco_motor_official_unit.mjs",
    "test:pricing-engine-homologada": "node ./tests/pricing/regressaoEnginePi.mjs",
    "test:pricing-engine-homologada:live": "node ./tests/pricing/regressaoEnginePi.mjs --live",
    "test:competition-daily-snapshot-diff": "node ./scripts/test_competition_daily_snapshot_diff_unit.mjs",
    "ssot:guard": "node ./scripts/ssot_guard_check.mjs",
    "backfill:recent-cost-snapshots": "node ./scripts/backfill_recent_cost_snapshots_dev.mjs"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.87.1",
    "@vercel/functions": "^3.0.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "node-fetch": "^3.3.2"
  }
